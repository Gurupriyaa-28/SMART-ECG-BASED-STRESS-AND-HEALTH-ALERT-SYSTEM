// ---------------- GSM FUNCTION ----------------
void sendSMS() {

  gsm.println("AT+CMGF=1");
  delay(1000);

  gsm.println("AT+CMGS=\"+91\""); // CHANGE NUMBER
  delay(1000);

  gsm.println("ALERT! Abnormal Heart Rate Detected!");
  delay(100);

  gsm.write(26); // CTRL+Z
  delay(5000);
}
